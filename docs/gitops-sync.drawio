<mxfile host="app.diagrams.net" agent="claude" version="24.0.0">
  <diagram name="GitOps Sync" id="gitops-sync">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t1" value="Varonis Restaurant API - GitOps Sync Flow (ArgoCD)" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontSize=20;align=left;verticalAlign=top;fontColor=#1e1e1e;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="800" height="30" as="geometry"/></mxCell>
        <mxCell id="t2" value="Pull model: the cluster converges to Git; CI never holds cluster credentials (ADR-004)" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontSize=12;align=left;verticalAlign=top;fontColor=#868e96;" vertex="1" parent="1"><mxGeometry x="40" y="50" width="800" height="20" as="geometry"/></mxCell>

        <mxCell id="tf" value="Terraform (bootstrap, one-time)&#10;helm release: argo-cd&#10;helm release: argocd-apps (renders the Application CR&#10;after the argo-cd release has registered the CRDs)" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=1;whiteSpace=wrap;html=1;fillColor=#e9ecef;strokeColor=#1e1e1e;fontSize=13;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="60" y="110" width="340" height="110" as="geometry"/></mxCell>

        <mxCell id="repo" value="GitHub repo (source of truth)&#10;&#10;helm/restaurant-api&#10;Chart.yaml · values.yaml · templates/" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3bf;strokeColor=#1e1e1e;fontSize=14;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="60" y="320" width="340" height="150" as="geometry"/></mxCell>

        <mxCell id="ci" value="CI build-deliver job&#10;pushes image to ECR, then commits the tag bump:&#10;chore(gitops): deploy &lt;sha&gt; [skip ci]" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe8cc;strokeColor=#1e1e1e;fontSize=13;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="60" y="560" width="340" height="100" as="geometry"/></mxCell>
        <mxCell id="e-ci-repo" value="git push (values.yaml bump)" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;endArrow=block;html=1;strokeColor=#1e1e1e;fontSize=12;fontColor=#1e1e1e;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="230" y="560" as="sourcePoint"/><mxPoint x="230" y="470" as="targetPoint"/></mxGeometry></mxCell>

