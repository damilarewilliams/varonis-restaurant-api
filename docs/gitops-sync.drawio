        <mxCell id="cluster-l" value="EKS cluster" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontSize=16;align=left;verticalAlign=top;fontColor=#495057;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="515" y="118" width="300" height="24" as="geometry"/></mxCell>

        <mxCell id="ns-argo" value="" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#868e96;fontSize=14;align=left;verticalAlign=top;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="540" y="160" width="700" height="500" as="geometry"/></mxCell>
        <mxCell id="ns-argo-l" value="argocd namespace" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontSize=14;align=left;verticalAlign=top;fontColor=#868e96;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="555" y="166" width="250" height="20" as="geometry"/></mxCell>

        <mxCell id="reposerver" value="repo-server&#10;clones the repo, renders the Helm&#10;chart to plain manifests" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#d0ebff;strokeColor=#1e1e1e;fontSize=13;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="570" y="210" width="310" height="90" as="geometry"/></mxCell>
        <mxCell id="controller" value="application-controller&#10;diffs desired (Git) vs live (cluster),&#10;applies the difference" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#d0ebff;strokeColor=#1e1e1e;fontSize=13;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="900" y="210" width="310" height="90" as="geometry"/></mxCell>
        <mxCell id="apiserver" value="api-server / UI&#10;status and manual operations&#10;(reached by port-forward only)" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#d0ebff;strokeColor=#1e1e1e;fontSize=13;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="570" y="330" width="310" height="80" as="geometry"/></mxCell>
        <mxCell id="redis" value="redis&#10;state cache" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#d0ebff;strokeColor=#1e1e1e;fontSize=13;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="900" y="330" width="310" height="80" as="geometry"/></mxCell>

        <mxCell id="appcr" value="Application CR: varonis-restaurant-api-dev&#10;source: this repo · path helm/restaurant-api · targetRevision main&#10;destination: in-cluster · namespace restaurant-api&#10;syncPolicy: automated (prune + selfHeal) · CreateNamespace=true" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#e5dbff;strokeColor=#1e1e1e;fontSize=13;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="570" y="450" width="640" height="130" as="geometry"/></mxCell>

        <mxCell id="ns-app" value="" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#868e96;fontSize=14;align=left;verticalAlign=top;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="540" y="720" width="700" height="330" as="geometry"/></mxCell>
        <mxCell id="ns-app-l" value="restaurant-api namespace (created by the sync)" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontSize=14;align=left;verticalAlign=top;fontColor=#868e96;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="555" y="726" width="450" height="20" as="geometry"/></mxCell>
        <mxCell id="appres" value="Deployment (rolling: maxSurge 1 / maxUnavailable 0)&#10;Service · ConfigMap · HPA · NetworkPolicy&#10;ServiceAccount (IRSA: DynamoDB read, one table)" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#b2f2bb;strokeColor=#1e1e1e;fontSize=14;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="570" y="770" width="640" height="230" as="geometry"/></mxCell>

        <mxCell id="rollback" value="Rollback&#10;git revert of the values bump;&#10;ArgoCD converges the cluster&#10;back to the previous image&#10;(immutable ECR tags)" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3bf;strokeColor=#1e1e1e;fontSize=13;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="1310" y="770" width="290" height="160" as="geometry"/></mxCell>

