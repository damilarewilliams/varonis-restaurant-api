        <mxCell id="e-rs-ctl" value="rendered manifests" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;endArrow=block;html=1;strokeColor=#1e1e1e;fontSize=12;fontColor=#1e1e1e;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="880" y="255" as="sourcePoint"/><mxPoint x="900" y="255" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="e-cr-ctl" value="declares desired state" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;endArrow=block;html=1;strokeColor=#1e1e1e;dashed=1;fontSize=12;fontColor=#1e1e1e;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1000" y="450" as="sourcePoint"/><mxPoint x="1030" y="300" as="targetPoint"/></mxGeometry></mxCell>
