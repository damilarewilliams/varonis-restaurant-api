<mxfile host="app.diagrams.net" agent="claude" version="24.0.0">
  <diagram name="EKS Architecture" id="eks-architecture">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1150" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t1" value="Varonis Restaurant API - EKS Cluster and Identity Architecture" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontSize=20;align=left;verticalAlign=top;fontColor=#1e1e1e;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="900" height="30" as="geometry"/></mxCell>
        <mxCell id="t2" value="Every identity is a role scoped to one job; no static keys anywhere (terraform/modules/eks + iam)" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontSize=12;align=left;verticalAlign=top;fontColor=#868e96;" vertex="1" parent="1"><mxGeometry x="40" y="50" width="900" height="20" as="geometry"/></mxCell>

        <mxCell id="cluster" value="" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#495057;fontSize=14;align=left;verticalAlign=top;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="40" y="100" width="880" height="960" as="geometry"/></mxCell>
        <mxCell id="cluster-l" value="EKS cluster: varonis-restaurant-api-dev (managed control plane, 3 AZs, authentication_mode: API)" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontSize=15;align=left;verticalAlign=top;fontColor=#495057;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="55" y="108" width="850" height="24" as="geometry"/></mxCell>

        <mxCell id="nodes" value="Managed node group&#10;t3.medium · min 2 / desired 2 / max 4 · private subnets only&#10;Add-ons: VPC CNI (NetworkPolicy enforcement) · CoreDNS · kube-proxy" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#e9ecef;strokeColor=#1e1e1e;fontSize=13;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="70" y="150" width="820" height="90" as="geometry"/></mxCell>

        <mxCell id="ns1" value="argocd&#10;ArgoCD (Terraform-installed)&#10;syncs the app from Git" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3bf;strokeColor=#1e1e1e;fontSize=13;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="70" y="280" width="390" height="100" as="geometry"/></mxCell>
        <mxCell id="ns2" value="arc-runners&#10;ARC scale set (Terraform-installed)&#10;ephemeral CD-verify runners, min 0&#10;SA: arc-runner" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3bf;strokeColor=#1e1e1e;fontSize=13;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="500" y="280" width="390" height="100" as="geometry"/></mxCell>
        <mxCell id="ns3" value="logging&#10;Fluent Bit DaemonSet (Terraform-installed)&#10;ships app stdout to CloudWatch&#10;SA: fluent-bit" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3bf;strokeColor=#1e1e1e;fontSize=13;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="70" y="410" width="390" height="100" as="geometry"/></mxCell>
        <mxCell id="ns4" value="restaurant-api&#10;the application (ArgoCD-deployed)&#10;default-deny NetworkPolicy&#10;SA: restaurant-api" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#b2f2bb;strokeColor=#1e1e1e;fontSize=13;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="500" y="410" width="390" height="100" as="geometry"/></mxCell>

        <mxCell id="oidc" value="Cluster OIDC provider&#10;pods exchange service account tokens&#10;for short-lived IAM credentials (IRSA)" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=1;whiteSpace=wrap;html=1;fillColor=#d0ebff;strokeColor=#1e1e1e;fontSize=13;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="70" y="560" width="820" height="80" as="geometry"/></mxCell>

        <mxCell id="irsa1" value="IRSA role: dev-api&#10;bound to restaurant-api/restaurant-api&#10;DynamoDB read (one table)&#10;+ kms:Decrypt (data key only)" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#e5dbff;strokeColor=#1e1e1e;fontSize=12;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="70" y="680" width="260" height="110" as="geometry"/></mxCell>
        <mxCell id="irsa2" value="IRSA role: dev-cd-runner&#10;bound to arc-runners/arc-runner&#10;eks:DescribeCluster&#10;+ access entry: namespaced View" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#e5dbff;strokeColor=#1e1e1e;fontSize=12;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="350" y="680" width="260" height="110" as="geometry"/></mxCell>
        <mxCell id="irsa3" value="IRSA role: dev-log-shipper&#10;bound to logging/fluent-bit&#10;write-only: CreateLogStream,&#10;PutLogEvents (one log group)" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#e5dbff;strokeColor=#1e1e1e;fontSize=12;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="630" y="680" width="260" height="110" as="geometry"/></mxCell>

        <mxCell id="entries" value="EKS access entries (API mode - no aws-auth ConfigMap)&#10;cluster creator: admin (bootstrap) · gha-terraform role: cluster admin (CI provisions the platform)&#10;cd-runner role: View, restaurant-api namespace only (verifies, never mutates - ArgoCD mutates)" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe8cc;strokeColor=#1e1e1e;fontSize=13;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="70" y="830" width="820" height="100" as="geometry"/></mxCell>

        <mxCell id="e-oidc1" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;endArrow=block;html=1;strokeColor=#1e1e1e;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="200" y="680" as="sourcePoint"/><mxPoint x="200" y="640" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="e-oidc2" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;endArrow=block;html=1;strokeColor=#1e1e1e;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="480" y="680" as="sourcePoint"/><mxPoint x="480" y="640" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="e-oidc3" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;endArrow=block;html=1;strokeColor=#1e1e1e;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="760" y="680" as="sourcePoint"/><mxPoint x="760" y="640" as="targetPoint"/></mxGeometry></mxCell>

        <mxCell id="aws" value="AWS services&#10;DynamoDB (KMS CMK) · CloudWatch Logs (KMS CMK) · ECR" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#eebefa;strokeColor=#1e1e1e;fontSize=13;align=center;verticalAlign=middle;fontColor=#1e1e1e;" vertex="1" parent="1"><mxGeometry x="1000" y="680" width="360" height="110" as="geometry"/></mxCell>
        <mxCell id="e-aws" value="scoped, short-lived access" style="sketch=1;curveFitting=1;jiggle=1;fillStyle=solid;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;endArrow=block;html=1;strokeColor=#1e1e1e;fontSize=12;fontColor=#1e1e1e;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="890" y="735" as="sourcePoint"/><mxPoint x="1000" y="735" as="targetPoint"/></mxGeometry></mxCell>

