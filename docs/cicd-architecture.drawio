<mxfile host="app.diagrams.net" agent="claude" version="24.0.0">
  <diagram name="CI-CD Architecture" id="cicd-architecture">
    <mxGraphModel dx="1600" dy="1800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="1545" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="3" value="Varonis Restaurant API - CI/CD Architecture" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontSize=20;align=left;verticalAlign=top;fontColor=#1e1e1e;dashed=0;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1000" height="30" as="geometry"/></mxCell><mxCell id="4" value="GitHub Actions (.github/workflows/ci.yml, deploy.yml) + GitOps via ArgoCD" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontSize=12;align=left;verticalAlign=top;fontColor=#868e96;dashed=0;" vertex="1" parent="1"><mxGeometry x="40" y="50" width="1000" height="20" as="geometry"/></mxCell><mxCell id="5" value="Developer opens Pull Request" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=1;whiteSpace=wrap;html=1;fillColor=#e9ecef;strokeColor=#1e1e1e;fontSize=13;align=center;verticalAlign=middle;fontColor=#1e1e1e;dashed=0;" vertex="1" parent="1"><mxGeometry x="380.0" y="90" width="480" height="45" as="geometry"/></mxCell><mxCell id="6" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;endArrow=block;html=1;strokeColor=#1e1e1e;dashed=0;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="620" y="135" as="sourcePoint"/><mxPoint x="620" y="170" as="targetPoint"/></mxGeometry></mxCell><mxCell id="7" value="" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#495057;fontSize=13;align=left;verticalAlign=top;fontColor=#1e1e1e;dashed=0;" vertex="1" parent="1"><mxGeometry x="350.0" y="170" width="540" height="150" as="geometry"/></mxCell><mxCell id="8" value="CI workflow (PR, required status checks)" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontSize=13;align=left;verticalAlign=top;fontColor=#495057;dashed=0;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="365.0" y="178" width="400" height="20" as="geometry"/></mxCell><mxCell id="9" value="python job&#10;checkout, setup-python 3.12&#10;ruff check&#10;mypy&#10;pytest" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3bf;strokeColor=#1e1e1e;fontSize=11;align=center;verticalAlign=middle;fontColor=#1e1e1e;dashed=0;" vertex="1" parent="1"><mxGeometry x="370.0" y="210" width="170" height="95" as="geometry"/></mxCell><mxCell id="10" value="terraform job&#10;terraform fmt -check&#10;init -backend=false&#10;terraform validate" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3bf;strokeColor=#1e1e1e;fontSize=11;align=center;verticalAlign=middle;fontColor=#1e1e1e;dashed=0;" vertex="1" parent="1"><mxGeometry x="555.0" y="210" width="170" height="95" as="geometry"/></mxCell><mxCell id="11" value="helm job&#10;helm lint&#10;helm template&#10;(render check)" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3bf;strokeColor=#1e1e1e;fontSize=11;align=center;verticalAlign=middle;fontColor=#1e1e1e;dashed=0;" vertex="1" parent="1"><mxGeometry x="740.0" y="210" width="170" height="95" as="geometry"/></mxCell><mxCell id="12" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;endArrow=block;html=1;strokeColor=#1e1e1e;dashed=0;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="620" y="320" as="sourcePoint"/><mxPoint x="620" y="355" as="targetPoint"/></mxGeometry></mxCell><mxCell id="13" value="Merge to main&#10;(branch protection + CODEOWNERS + green CI)" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=1;whiteSpace=wrap;html=1;fillColor=#e9ecef;strokeColor=#1e1e1e;fontSize=12;align=center;verticalAlign=middle;fontColor=#1e1e1e;dashed=0;" vertex="1" parent="1"><mxGeometry x="380.0" y="355" width="480" height="45" as="geometry"/></mxCell><mxCell id="14" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;endArrow=block;html=1;strokeColor=#1e1e1e;dashed=0;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="620" y="400" as="sourcePoint"/><mxPoint x="620" y="435" as="targetPoint"/></mxGeometry></mxCell><mxCell id="15" value="Deploy workflow (push: main)&#10;changes job - dorny/paths-filter&#10;infra changed? (terraform/**)   app changed? (app/**, Dockerfile, pyproject.toml)" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=1;whiteSpace=wrap;html=1;fillColor=#e9ecef;strokeColor=#1e1e1e;fontSize=11;align=center;verticalAlign=middle;fontColor=#1e1e1e;dashed=0;" vertex="1" parent="1"><mxGeometry x="380.0" y="435" width="480" height="60" as="geometry"/></mxCell><mxCell id="16" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;endArrow=block;html=1;strokeColor=#1e1e1e;dashed=0;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="620" y="495" as="sourcePoint"/><mxPoint x="620" y="530" as="targetPoint"/></mxGeometry></mxCell><mxCell id="17" value="terraform-plan  (if infra changed)&#10;env: dev-infra-plan (unprotected)&#10;OIDC → assume AWS_TERRAFORM_ROLE_ARN&#10;verify identity + EKS auth&#10;fmt → init → validate → plan&#10;upload tfplan artifact" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#d0ebff;strokeColor=#1e1e1e;fontSize=11;align=center;verticalAlign=middle;fontColor=#1e1e1e;dashed=0;" vertex="1" parent="1"><mxGeometry x="380.0" y="530" width="480" height="130" as="geometry"/></mxCell><mxCell id="18" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;endArrow=block;html=1;strokeColor=#1e1e1e;dashed=0;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="620" y="660" as="sourcePoint"/><mxPoint x="620" y="695" as="targetPoint"/></mxGeometry></mxCell><mxCell id="19" value="Manual approval gate&#10;GitHub Environment &quot;dev-infra&quot;: required reviewer" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe3e3;strokeColor=#1e1e1e;fontSize=12;align=center;verticalAlign=middle;fontColor=#1e1e1e;dashed=1;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="380.0" y="695" width="480" height="50" as="geometry"/></mxCell><mxCell id="20" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;endArrow=block;html=1;strokeColor=#1e1e1e;dashed=0;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="620" y="745" as="sourcePoint"/><mxPoint x="620" y="780" as="targetPoint"/></mxGeometry></mxCell><mxCell id="21" value="terraform-apply  (env: dev-infra)&#10;OIDC → assume AWS_TERRAFORM_ROLE_ARN&#10;download tfplan artifact&#10;terraform apply tfplan (exact reviewed plan)&#10;verify EKS cluster ACTIVE" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#d0ebff;strokeColor=#1e1e1e;fontSize=11;align=center;verticalAlign=middle;fontColor=#1e1e1e;dashed=0;" vertex="1" parent="1"><mxGeometry x="380.0" y="780" width="480" height="90" as="geometry"/></mxCell><mxCell id="22" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;endArrow=block;html=1;strokeColor=#1e1e1e;dashed=0;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="620" y="870" as="sourcePoint"/><mxPoint x="620" y="905" as="targetPoint"/></mxGeometry></mxCell><mxCell id="23" value="build-deliver  (if app changed; needs terraform-apply success/skipped)&#10;OIDC → assume AWS_DELIVERY_ROLE_ARN&#10;ECR login → docker build&#10;Trivy scan (gate: fail on HIGH/CRITICAL)&#10;docker push → ECR&#10;yq bump image.repository/tag in values.yaml&#10;git commit &quot;chore(gitops): deploy &lt;sha&gt; [skip ci]&quot; → push main" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#ffd8a8;strokeColor=#1e1e1e;fontSize=11;align=center;verticalAlign=middle;fontColor=#1e1e1e;dashed=0;" vertex="1" parent="1"><mxGeometry x="380.0" y="905" width="480" height="150" as="geometry"/></mxCell><mxCell id="24" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;endArrow=block;html=1;strokeColor=#1e1e1e;dashed=0;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="620" y="1055" as="sourcePoint"/><mxPoint x="620" y="1090" as="targetPoint"/></mxGeometry></mxCell><mxCell id="25" value="ArgoCD  (in-cluster, namespace argocd)&#10;detects values.yaml commit (poll ~3min or webhook)&#10;repo-server renders Helm chart&#10;application-controller syncs (prune + selfHeal)" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#b2f2bb;strokeColor=#1e1e1e;fontSize=11;align=center;verticalAlign=middle;fontColor=#1e1e1e;dashed=0;" vertex="1" parent="1"><mxGeometry x="380.0" y="1090" width="480" height="90" as="geometry"/></mxCell><mxCell id="26" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;endArrow=block;html=1;strokeColor=#1e1e1e;dashed=0;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="620" y="1180" as="sourcePoint"/><mxPoint x="620" y="1215" as="targetPoint"/></mxGeometry></mxCell><mxCell id="27" value="cd-verify  (runs on: arc-cd - self-hosted ARC runner, in-cluster, IRSA)&#10;wait for ArgoCD to converge to &lt;sha&gt;&#10;kubectl rollout status (timeout 300s)&#10;GET /health/live, /health/ready&#10;smoke test: /api/v1/recommendations&#10;(+ 422 on invalid query param)" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#e5dbff;strokeColor=#1e1e1e;fontSize=11;align=center;verticalAlign=middle;fontColor=#1e1e1e;dashed=0;" vertex="1" parent="1"><mxGeometry x="380.0" y="1215" width="480" height="150" as="geometry"/></mxCell><mxCell id="28" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;endArrow=block;html=1;strokeColor=#1e1e1e;dashed=0;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="620" y="1365" as="sourcePoint"/><mxPoint x="620" y="1400" as="targetPoint"/></mxGeometry></mxCell><mxCell id="29" value="Deployment verified - summary posted to GITHUB_STEP_SUMMARY" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=1;whiteSpace=wrap;html=1;fillColor=#e9ecef;strokeColor=#1e1e1e;fontSize=12;align=center;verticalAlign=middle;fontColor=#1e1e1e;dashed=0;" vertex="1" parent="1"><mxGeometry x="380.0" y="1400" width="480" height="45" as="geometry"/></mxCell><mxCell id="30" value="GitHub OIDC Federation (ADR-008)&#10;Short-lived role assumption&#10;No static AWS keys in GitHub Secrets&#10;Roles: AWS_TERRAFORM_ROLE_ARN,&#10;AWS_DELIVERY_ROLE_ARN (Actions variables)" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#f1f3f5;strokeColor=#1e1e1e;fontSize=11;align=center;verticalAlign=middle;fontColor=#1e1e1e;dashed=0;" vertex="1" parent="1"><mxGeometry x="920.0" y="530" width="300" height="90" as="geometry"/></mxCell><mxCell id="31" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;endArrow=block;html=1;strokeColor=#1e1e1e;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="920.0" y="575" as="sourcePoint"/><mxPoint x="860.0" y="575" as="targetPoint"/></mxGeometry></mxCell><mxCell id="32" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;endArrow=block;html=1;strokeColor=#1e1e1e;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="920.0" y="575" as="sourcePoint"/><mxPoint x="860.0" y="950" as="targetPoint"/></mxGeometry></mxCell><mxCell id="33" value="Amazon ECR (private, scan-on-push,&#10;immutable tags)&#10;&#10;Trivy - 2nd layer: continuous scan&#10;behind the pipeline gate" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#f1f3f5;strokeColor=#1e1e1e;fontSize=11;align=center;verticalAlign=middle;fontColor=#1e1e1e;dashed=0;" vertex="1" parent="1"><mxGeometry x="920.0" y="945" width="300" height="80" as="geometry"/></mxCell><mxCell id="34" value="Runner topology (ADR-005)&#10;CI, Terraform, Docker build/push:&#10;→ GitHub-hosted (no AWS/cluster access)&#10;&#10;CD verify:&#10;→ self-hosted ARC on EKS&#10;(ephemeral pod per job, scaled from&#10;zero, IRSA - not static creds)" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=#f1f3f5;strokeColor=#1e1e1e;fontSize=11;align=center;verticalAlign=middle;fontColor=#1e1e1e;dashed=0;" vertex="1" parent="1"><mxGeometry x="920.0" y="1215" width="300" height="120" as="geometry"/></mxCell><mxCell id="35" value="Legend:" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontSize=13;align=left;verticalAlign=top;fontColor=#1e1e1e;dashed=0;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="350.0" y="1485" width="80" height="20" as="geometry"/></mxCell><mxCell id="36" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;endArrow=block;html=1;strokeColor=#1e1e1e;dashed=0;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="435.0" y="1495" as="sourcePoint"/><mxPoint x="495.0" y="1495" as="targetPoint"/></mxGeometry></mxCell><mxCell id="37" value="pipeline flow" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontSize=13;align=left;verticalAlign=top;fontColor=#1e1e1e;dashed=0;" vertex="1" parent="1"><mxGeometry x="505.0" y="1485" width="140" height="20" as="geometry"/></mxCell><mxCell id="38" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;endArrow=block;html=1;strokeColor=#1e1e1e;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="660.0" y="1495" as="sourcePoint"/><mxPoint x="720.0" y="1495" as="targetPoint"/></mxGeometry></mxCell><mxCell id="39" value="supporting system / auth" style="sketch=1;curveFitting=1;jiggle=2;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontSize=13;align=left;verticalAlign=top;fontColor=#1e1e1e;dashed=0;" vertex="1" parent="1"><mxGeometry x="730.0" y="1485" width="260" height="20" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
